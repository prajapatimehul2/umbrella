# Postgres connection string.
# Easiest free option: create a project at https://neon.tech and paste its
# connection string here. Works with any Postgres (Neon, Supabase, Railway, local).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Secret used to sign session cookies. Generate one with:
#   openssl rand -base64 32
JWT_SECRET="change-me-to-a-long-random-string"

# Set to "true" ONLY when the app is served over HTTPS (e.g. behind certbot/TLS).
# Browsers refuse to store Secure cookies over plain HTTP, which breaks sign-in,
# so leave this unset/false for a bare http:// deployment.
COOKIE_SECURE="false"
